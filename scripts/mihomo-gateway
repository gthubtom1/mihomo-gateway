#!/usr/bin/env bash
set -euo pipefail

ENV_FILE="/root/mihomo-gateway/env"
CONFIG="/etc/mihomo/config.yaml"

if [[ -f "${ENV_FILE}" ]]; then
  # shellcheck disable=SC1090
  source "${ENV_FILE}"
fi

need_cmd() { command -v "$1" >/dev/null 2>&1 || { echo "missing $1"; exit 1; }; }
need_cmd python3
need_cmd systemctl
need_cmd curl

json_payload() {
  local kind="$1"; shift
  if [[ "${kind}" == "provider" ]]; then
    local name="$1" interval="$2"
    python3 -c '
import json, sys
print(json.dumps({"name": sys.argv[1], "url": sys.stdin.read(), "interval": int(sys.argv[2])}, ensure_ascii=False))
' "${name}" "${interval}"
    return
  fi
  python3 - "$kind" "$@" <<'PY'
import json
import sys

kind = sys.argv[1]
if kind == "socks":
    payload = {"port": int(sys.argv[2]), "group": sys.argv[3]}
else:
    raise SystemExit("unknown payload type")
print(json.dumps(payload, ensure_ascii=False))
PY
}

api() {
  local method="$1"; shift
  local path="$1"; shift
  local body="${1:-0}"
  local secret="${MIHOMO_SECRET:-}"
  [[ -n "${secret}" ]] || { echo "MIHOMO_SECRET missing in ${ENV_FILE}"; exit 1; }
  local header_file status
  header_file="$(mktemp)"
  chmod 600 "${header_file}"
  printf 'Authorization: Bearer %s\nContent-Type: application/json\n' "${secret}" > "${header_file}"
  if [[ "${body}" == "1" ]]; then
    if curl -fsS -X "${method}" -H "@${header_file}" --data-binary @- \
      "http://127.0.0.1:${PANEL_API_PORT:-9092}${path}"; then
      status=0
    else
      status=$?
    fi
  else
    if curl -fsS -X "${method}" -H "@${header_file}" \
      "http://127.0.0.1:${PANEL_API_PORT:-9092}${path}"; then
      status=0
    else
      status=$?
    fi
  fi
  rm -f "${header_file}"
  return "${status}"
}

cmd="${1:-status}"
shift || true

case "${cmd}" in
  status)
    systemctl is-active mihomo mihomo-gateway-api nginx || true
    echo "panel: http://${PUBLIC_IP:-127.0.0.1}:${PANEL_PORT:-9090}/"
    ;;
  socks)
    sub="${1:-list}"; shift || true
    case "${sub}" in
      list) api GET /panel-api/socks | python3 -m json.tool ;;
      add)
        port="${1:-}"; group="${2:-PROXY}"
        [[ -n "${port}" ]] || { echo "usage: mihomo-gateway socks add <port> [group]"; exit 1; }
        json_payload socks "${port}" "${group}" | api POST /panel-api/socks 1 | python3 -m json.tool
        ;;
      del)
        port="${1:-}"
        [[ -n "${port}" ]] || { echo "usage: mihomo-gateway socks del <port>"; exit 1; }
        api DELETE "/panel-api/socks?port=${port}" | python3 -m json.tool
        ;;
      migrate) api POST /panel-api/socks/migrate | python3 -m json.tool ;;
      *) echo "usage: mihomo-gateway socks list|add|del|migrate"; exit 1 ;;
    esac
    ;;
  provider)
    sub="${1:-list}"; shift || true
    case "${sub}" in
      list) api GET /panel-api/providers | python3 -m json.tool ;;
      add)
        name="${1:-}"; url="${2:-}"; interval="${3:-3600}"
        [[ -n "${name}" && -n "${url}" ]] || { echo "usage: mihomo-gateway provider add <name> <url> [interval]"; exit 1; }
        if [[ "${url}" == "-" ]]; then
          url="$(cat)"
        fi
        printf '%s' "${url}" | json_payload provider "${name}" "${interval}" \
          | api POST /panel-api/providers 1 | python3 -m json.tool
        ;;
      del)
        name="${1:-}"
        [[ -n "${name}" ]] || { echo "usage: mihomo-gateway provider del <name>"; exit 1; }
        api DELETE "/panel-api/providers?name=${name}" | python3 -m json.tool
        ;;
      *) echo "usage: mihomo-gateway provider list|add|del"; exit 1 ;;
    esac
    ;;
  credentials)
    cat /root/mihomo-gateway/credentials.txt
    ;;
  *)
    echo "usage: mihomo-gateway status|socks|provider|credentials"
    exit 1
    ;;
esac
